### Game Station Auth API - Testing Examples
### Pastikan server sudah running: npm run dev

@baseUrl = http://localhost:3000
@accessToken = 
@refreshToken = 

### Health Check
GET {{baseUrl}}/health

### ===============================================
### 1. REGISTER - Create new user
### ===============================================
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "email": "customer@test.com",
  "password": "password123",
  "fullname": "Customer Test",
  "phone": "081234567890",
  "role": "customer"
}

### ===============================================
### 2. LOGIN - Login with email & password
### ===============================================
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "customer@test.com",
  "password": "password123"
}

### ===============================================
### 3. LOGIN OTP - Step 1: Request OTP
### ===============================================
POST {{baseUrl}}/auth/login-otp
Content-Type: application/json

{
  "email": "customer@test.com"
}

### ===============================================
### 4. LOGIN OTP - Step 2: Verify OTP
### (Check console for OTP code)
### ===============================================
POST {{baseUrl}}/auth/login-otp
Content-Type: application/json

{
  "email": "customer@test.com",
  "otp": "123456"
}

### ===============================================
### 5. REFRESH TOKEN - Get new access token
### ===============================================
POST {{baseUrl}}/auth/refresh-token
Content-Type: application/json

{
  "refreshToken": "{{refreshToken}}"
}

### ===============================================
### 6. LOGOUT - Invalidate token
### ===============================================
POST {{baseUrl}}/auth/logout
Authorization: Bearer {{accessToken}}

### ===============================================
### TEST CASES - Error Handling
### ===============================================

### Register with existing email
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "email": "customer@test.com",
  "password": "password123",
  "fullname": "Another User"
}

### Login with wrong password
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "customer@test.com",
  "password": "wrongpassword"
}

### Login with non-existent email
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "notfound@test.com",
  "password": "password123"
}

### Register with invalid email
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "email": "invalid-email",
  "password": "password123",
  "fullname": "Test User"
}

### Register without required fields
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "email": "test@test.com"
}

### Refresh with invalid token
POST {{baseUrl}}/auth/refresh-token
Content-Type: application/json

{
  "refreshToken": "invalid-token"
}

### ===============================================
### ADMIN & SUPER ADMIN TESTING
### ===============================================

### Register Admin
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "email": "admin@gamestation.com",
  "password": "admin123",
  "fullname": "Admin User",
  "role": "admin"
}

### Register Super Admin
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "email": "superadmin@gamestation.com",
  "password": "super123",
  "fullname": "Super Admin User",
  "role": "super_admin"
}

### CUSTOMER
password123

### ADMIN
admin123

### OWNER
Owner12345!

### ===============================================
### HOLIDAY API - National Holidays Management
### ===============================================

### Sync National Holidays for 2025 (from API)
POST {{baseUrl}}/holidays/national/sync/2025
Authorization: Bearer {{accessToken}}

### Sync National Holidays for 2026
POST {{baseUrl}}/holidays/national/sync/2026
Authorization: Bearer {{accessToken}}

### Get All Holidays
GET {{baseUrl}}/holidays

### Get Holidays by Branch
GET {{baseUrl}}/holidays?branchId=1

### Get Holidays by Year
GET {{baseUrl}}/holidays?year=2025

### Get Holidays by Date Range
GET {{baseUrl}}/holidays?startDate=2025-01-01&endDate=2025-12-31

### Add Custom Holiday
POST {{baseUrl}}/holidays/custom
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "branchId": "1",
  "date": "2025-10-15",
  "name": "Anniversary Cabang Jakarta",
  "description": "Ulang tahun ke-5 cabang Jakarta"
}

### Update Holiday
PUT {{baseUrl}}/holidays/1
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "name": "Libur Lebaran (Updated)",
  "description": "Idul Fitri 1446 H - Updated"
}

### Delete Holiday
DELETE {{baseUrl}}/holidays/1
Authorization: Bearer {{accessToken}}

### Delete National Holiday (all branches)
DELETE {{baseUrl}}/holidays/national/2025-12-25?name=Hari Raya Natal
Authorization: Bearer {{accessToken}}

### ===============================================
### HOLIDAY API - UPDATED (Refactored Version)
### ===============================================

### 1. Sync National Holidays - All Branches (Default)
POST {{baseUrl}}/holidays/national/sync/2026
Authorization: Bearer {{accessToken}}

### 2. Sync National Holidays - Specific Branches
POST {{baseUrl}}/holidays/national/sync/2026?branchIds=1,2,3
Authorization: Bearer {{accessToken}}

### 3. Sync National Holidays - All Branches with Overwrite
POST {{baseUrl}}/holidays/national/sync/2026?overwrite=true
Authorization: Bearer {{accessToken}}

### 4. Sync National Holidays - Delete Existing then Sync
POST {{baseUrl}}/holidays/national/sync/2026?deleteExisting=true
Authorization: Bearer {{accessToken}}

### 5. Sync National Holidays - Multiple Options
POST {{baseUrl}}/holidays/national/sync/2026?branchIds=1,2&overwrite=true&deleteExisting=true
Authorization: Bearer {{accessToken}}

### 6. Add Custom Holiday - To All Branches
POST {{baseUrl}}/holidays/custom
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "date": "2026-03-15",
  "name": "Company Anniversary",
  "description": "Celebrating 10 years"
}

### 7. Add Custom Holiday - To Specific Branches
POST {{baseUrl}}/holidays/custom?branchIds=1,2,3
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "date": "2026-06-01",
  "name": "Mid Year Celebration",
  "description": "Team celebration event"
}

### 8. Add Custom Holiday - With Overwrite (Update if exists)
POST {{baseUrl}}/holidays/custom?branchIds=1&overwrite=true
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "date": "2026-03-15",
  "name": "Company Anniversary",
  "description": "Updated description"
}

### 9. Add Multiple Custom Holidays - To All Branches
POST {{baseUrl}}/holidays/custom/bulk
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "holidays": [
    {
      "date": "2026-03-15",
      "name": "Company Anniversary"
    },
    {
      "date": "2026-12-25",
      "name": "Christmas Holiday"
    },
    {
      "date": "2026-01-01",
      "name": "New Year Celebration"
    }
  ]
}

### 10. Add Multiple Custom Holidays - To Specific Branches with Overwrite
POST {{baseUrl}}/holidays/custom/bulk?branchIds=1,2&overwrite=true
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "holidays": [
    {
      "date": "2026-03-15",
      "name": "Company Anniversary",
      "description": "10 year celebration"
    },
    {
      "date": "2026-12-25",
      "name": "Christmas Holiday"
    }
  ]
}

### 11. Get Branch Holidays - All
GET {{baseUrl}}/branches/1/holidays
Authorization: Bearer {{accessToken}}

### 12. Get Branch Holidays - With Date Range
GET {{baseUrl}}/branches/1/holidays?startDate=2026-01-01&endDate=2026-12-31
Authorization: Bearer {{accessToken}}

### 13. Get Branch Holidays - Specific Month
GET {{baseUrl}}/branches/1/holidays?startDate=2026-03-01&endDate=2026-03-31
Authorization: Bearer {{accessToken}}

### 14. Delete Holiday by ID
DELETE {{baseUrl}}/holidays/1
Authorization: Bearer {{accessToken}}

### 15. Delete Holidays by Date Range - All Branches
DELETE {{baseUrl}}/holidays/delete-range?startDate=2026-01-01&endDate=2026-01-31
Authorization: Bearer {{accessToken}}

### 16. Delete Holidays by Date Range - Specific Branches
DELETE {{baseUrl}}/holidays/delete-range?branchIds=1,2&startDate=2026-01-01&endDate=2026-01-31
Authorization: Bearer {{accessToken}}

### 17. Delete Holidays by Date Range - Single Branch
DELETE {{baseUrl}}/holidays/delete-range?branchIds=1&startDate=2026-02-01&endDate=2026-02-28
Authorization: Bearer {{accessToken}}

### ===============================================
### USER ENDPOINTS
### ===============================================

### Update User Information - Own Account (SUCCESS)
PUT {{baseUrl}}/users/1
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "email": "newemail@example.com",
  "fullname": "Nama Baru",
  "phone": "+6281234567890"
}

### Update User Information - Partial Update (only email)
PUT {{baseUrl}}/users/1
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "email": "anotheremail@example.com"
}

### Update User Information - Partial Update (only phone)
PUT {{baseUrl}}/users/1
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "phone": "+62812345678901"
}

### Update User Information - Other User (FAIL - Unauthorized)
PUT {{baseUrl}}/users/2
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "email": "otheremail@example.com",
  "fullname": "Other User Name"
}

### Update User Information - Invalid Email Format
PUT {{baseUrl}}/users/1
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "email": "invalid-email"
}

### Update User Information - Phone Invalid Format
PUT {{baseUrl}}/users/1
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "phone": "123"
}

### Update User Information - Fullname Too Short
PUT {{baseUrl}}/users/1
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "fullname": "ab"
}

### Update User Information - No Fields to Update
PUT {{baseUrl}}/users/1
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
}

### Update User Information - Without Token (FAIL - Unauthorized)
PUT {{baseUrl}}/users/1
Content-Type: application/json

{
  "email": "newemail@example.com"
}

### ===============================================
### ANNOUNCEMENT ENDPOINTS
### ===============================================

### Create Announcement (Admin/Owner Only)
POST {{baseUrl}}/announcements
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "title": "Penawaran Spesial Bulan Ini",
  "content": "Dapatkan diskon 20% untuk semua pemesanan device gaming",
  "forBranch": 1,
  "startDate": "2026-02-05T00:00:00Z",
  "endDate": "2026-02-28T23:59:59Z"
}

### Create Global Announcement (All Branches)
POST {{baseUrl}}/announcements
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "title": "Maintenance System",
  "content": "Server akan melakukan maintenance pada tanggal 6 Februari 2026",
  "startDate": "2026-02-06T00:00:00Z",
  "endDate": "2026-02-06T23:59:59Z"
}

### Get All Announcements with Pagination
GET {{baseUrl}}/announcements?skip=0&take=10
Content-Type: application/json

### Get Announcements for Specific Branch
GET {{baseUrl}}/announcements?skip=0&take=10&branchId=1
Content-Type: application/json

### Get Active Announcements Only (Public)
GET {{baseUrl}}/announcements/active?skip=0&take=10
Content-Type: application/json

### Get Active Announcements for Specific Branch
GET {{baseUrl}}/announcements/active?skip=0&take=10&branchId=1
Content-Type: application/json

### Get Announcement by ID
GET {{baseUrl}}/announcements/1
Content-Type: application/json

### Update Announcement (Admin/Owner Only)
PUT {{baseUrl}}/announcements/1
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "title": "Penawaran Spesial Update",
  "endDate": "2026-03-15T23:59:59Z"
}

### Update Announcement - Partial Update (only title)
PUT {{baseUrl}}/announcements/1
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "title": "Judul Announcement Baru"
}

### Delete Announcement (Admin/Owner Only)
DELETE {{baseUrl}}/announcements/1
Authorization: Bearer {{accessToken}}

### Create Announcement - Invalid Date (endDate <= startDate)
POST {{baseUrl}}/announcements
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "title": "Invalid Announcement",
  "content": "This will fail because endDate is before startDate",
  "startDate": "2026-02-28T23:59:59Z",
  "endDate": "2026-02-05T00:00:00Z"
}

### Create Announcement - Missing Required Field
POST {{baseUrl}}/announcements
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "title": "Missing Content",
  "startDate": "2026-02-05T00:00:00Z",
  "endDate": "2026-02-28T23:59:59Z"
}