{
  "watch": ["src"],
  "ext": "ts,json",
  "ignore": ["src/**/*.spec.ts", "src/**/*.test.ts"],
  "exec": "ts-node src/index.ts",
  "signal": "SIGTERM",
  "env": {
    "NODE_ENV": "development"
  },
  "events": {
    "restart": "echo '[nodemon] Restarting...'",
    "crash": "echo '[nodemon] App crashed - waiting for changes...'"
  }
}
