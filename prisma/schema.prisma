// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Enums
enum UserRole {
  customer
  admin
  owner
}

enum DeviceType {
  ps
  racing
  vr
  pc
  arcade
}

enum DeviceVersion {
  ps4
  ps5
  racing_standard
  racing_pro
  vr_meta
  vr_pico
  pc_standard
  pc_gaming
  arcade_standard
}

enum CategoryTier {
  regular
  vip
  vvip
}

enum RoomAndDeviceStatus {
  available
  maintenance
  in_use
}

enum OrderStatus {
  cart
  pending
  confirmed
  completed
  cancelled
}

enum PaymentStatus {
  pending
  unpaid
  paid
  failed
  refund_pending
}

enum PaymentMethod {
  cash
  e_wallet
  bank_transfer
  gateway
}

enum PaymentProviderStatus {
  pending
  paid
  failed
  refunded
}

enum PaymentProvider {
  // E-wallet providers
  qris
  gopay
  ovo
  dana
  shopeepay
  linkaja
  // Bank transfer providers
  bca
  bri
  bni
  mandiri
  permata
  cimb
  // Payment gateway providers
  midtrans
  xendit
  doku
}

enum SessionStatus {
  running
  stopped
}

enum AdminRole {
  staff
  manager
}

enum NotificationChannel {
  push
  email
  sms
}

enum NotificationStatus {
  pending
  sent
  failed
}

enum SubscriptionStatus {
  active
  expired
  cancelled
}

enum AnnouncementPriority {
  low
  medium
  high
}

// Models
model User {
  id           BigInt   @id @default(autoincrement())
  email        String   @unique @db.VarChar(255)
  passwordHash String?  @map("password_hash") @db.VarChar(255)
  fullname     String   @db.VarChar(100)
  role         UserRole
  phone        String?  @db.VarChar(20)

  // Email Verification Fields
  isVerified               Boolean   @default(false) @map("is_verified")
  verificationToken        String?   @map("verification_token") @db.VarChar(255)
  verificationKey          String?   @map("verification_key") @db.VarChar(96)
  verificationTokenExpires DateTime? @map("verification_token_expires")
  verificationSentAt       DateTime? @map("verification_sent_at")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime? @updatedAt @map("updated_at") @db.Timestamp(6)

  // Relations
  owner         Owner?
  orders        Order[]
  notifications Notification[]
  admin         Admin?
  reviews       Review[]
  auditLogs     AuditLog[]

  @@index([email], name: "idx_users_email")
  @@map("users")
}

model Owner {
  id          BigInt    @id @default(autoincrement())
  userId      BigInt    @unique @map("user_id")
  companyName String    @map("company_name") @db.VarChar(150)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime? @updatedAt @map("updated_at") @db.Timestamp(6)

  // Relations
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  branches      Branch[]
  subscriptions Subscription[]

  @@map("owners")
}

model Branch {
  id        BigInt    @id @default(autoincrement())
  ownerId   BigInt    @map("owner_id")
  name      String    @db.VarChar(120)
  address   String    @db.Text
  phone     String    @db.VarChar(20)
  timezone  String    @default("Asia/Jakarta") @db.VarChar(50)
  openTime  String    @map("open_time") @db.VarChar(5)
  closeTime String    @map("close_time") @db.VarChar(5)
  amenities Json?     @default("[]")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime? @updatedAt @map("updated_at") @db.Timestamp(6)

  // Relations
  owner                Owner                 @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  admins               Admin[]
  category             Category[]
  roomAndDevices       roomAndDevice[]
  orders               Order[]
  advanceBookingPrices AdvanceBookingPrice[]
  branchHolidays       BranchHoliday[]
  reviews              Review[]
  paymentMethods       BranchPaymentMethod[]
  announcements        Announcement[]

  @@index([ownerId], name: "idx_branches_owner")
  @@map("branches")
}

model Category {
  id           BigInt       @id @default(autoincrement())
  branchId     BigInt       @map("branch_id")
  name         String       @db.VarChar(50)
  description  String?      @db.Text
  tier         CategoryTier
  pricePerHour Decimal      @map("price_per_hour") @db.Decimal(12, 2)
  amenities    Json?        @default("[]")
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt    DateTime?    @updatedAt @map("updated_at") @db.Timestamp(6)

  // Relations
  branch         Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  roomAndDevices roomAndDevice[]

  @@unique([branchId, name, tier])
  @@map("categories")
}

model roomAndDevice {
  id         BigInt  @id @default(autoincrement())
  branchId   BigInt  @map("branch_id")
  categoryId BigInt? @map("category_id")

  // Device
  name         String         @db.VarChar(50)
  deviceType   DeviceType     @map("device_type")
  version      DeviceVersion? @map("version")
  pricePerHour Decimal        @map("price_per_hour") @db.Decimal(12, 2)

  // Room
  roomNumber String?             @map("room_number") @db.VarChar(20)
  status     RoomAndDeviceStatus @default(available)
  createdAt  DateTime            @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt  DateTime?           @updatedAt @map("updated_at") @db.Timestamp(6)

  // Relations
  category               Category?               @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  games                  GameAvailability[]
  orderItems             OrderItem[]
  availabilityExceptions AvailabilityException[]
  sessions               Session[]
  branch                 Branch                  @relation(fields: [branchId], references: [id])

  @@unique([categoryId, name, deviceType])
  @@index([categoryId, deviceType], name: "idx_device_category_branch_type")
  @@map("room_and_devices")
}

model AdvanceBookingPrice {
  id            BigInt   @id @default(autoincrement())
  branchId      BigInt   @map("branch_id")
  minDays       Int      @map("min_days")
  maxDays       Int      @map("max_days")
  additionalFee Decimal  @map("additional_fee") @db.Decimal(12, 2)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  // Relations
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([branchId, minDays, maxDays])
  @@map("advance_booking_prices")
}

model Game {
  id         BigInt      @id @default(autoincrement())
  name       String      @db.VarChar(100)
  deviceType DeviceType?
  createdAt  DateTime    @default(now()) @map("created_at") @db.Timestamp(6)

  // Relations
  gameAvailability GameAvailability[]

  @@map("games")
}

model GameAvailability {
  id              BigInt   @id @default(autoincrement())
  gameId          BigInt   @map("game_id")
  roomAndDeviceId BigInt   @map("room_and_device_id")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  // Relations
  game          Game          @relation(fields: [gameId], references: [id], onDelete: Cascade)
  roomAndDevice roomAndDevice @relation(fields: [roomAndDeviceId], references: [id])

  @@unique([gameId, roomAndDeviceId])
  @@map("game_availability")
}

model AvailabilityException {
  id              BigInt   @id @default(autoincrement())
  roomAndDeviceId BigInt   @map("room_and_device_id")
  startAt         DateTime @map("start_at") @db.Timestamp(6)
  endAt           DateTime @map("end_at") @db.Timestamp(6)
  reason          String?  @db.VarChar(255)

  // Relations
  roomAndDevice roomAndDevice @relation(fields: [roomAndDeviceId], references: [id], onDelete: Cascade)

  @@map("availability_exceptions")
}

model Order {
  id                     BigInt        @id @default(autoincrement())
  orderCode              String        @unique @map("order_code") @db.VarChar(32)
  customerId             BigInt?       @map("customer_id")
  branchId               BigInt        @map("branch_id")
  status                 OrderStatus
  totalAmount            Decimal       @map("total_amount") @db.Decimal(12, 2)
  createdAt              DateTime      @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt              DateTime?     @updatedAt @map("updated_at") @db.Timestamp(6)
  paymentId              BigInt?       @map("payment_id")
  paymentStatus          PaymentStatus @map("payment_status")
  paymentProofFile       String?       @map("payment_proof_file") @db.Text
  paymentProofUploadedAt DateTime?     @map("payment_proof_uploaded_at") @db.Timestamp(6)
  guestCustomerName      String?       @map("guest_customer_name") @db.VarChar(100)
  guestCustomerPhone     String?       @map("guest_customer_phone") @db.VarChar(20)
  guestCustomerEmail     String?       @map("guest_customer_email") @db.VarChar(255)
  notes                  String?       @db.Text

  // Relations
  customer          User?                @relation(fields: [customerId], references: [id], onDelete: Cascade)
  branch            Branch               @relation(fields: [branchId], references: [id], onDelete: Cascade)
  paymentMethodUsed BranchPaymentMethod? @relation(fields: [paymentId], references: [id])
  orderItems        OrderItem[]
  session           Session?
  payment           Payment?

  @@index([customerId], name: "idx_orders_customer")
  @@index([branchId], name: "idx_orders_branch_booking")
  @@map("orders")
}

model OrderItem {
  id                BigInt   @id @default(autoincrement())
  orderId           BigInt   @map("order_id")
  roomAndDeviceId   BigInt   @map("room_and_device_id")
  bookingStart      DateTime @map("booking_start") @db.Timestamp(6)
  bookingEnd        DateTime @map("booking_end") @db.Timestamp(6)
  durationMinutes   Int      @map("duration_minutes")
  price             Decimal  @db.Decimal(12, 2)
  baseAmount        Decimal  @map("base_amount") @db.Decimal(12, 2)
  categoryFee       Decimal  @default(0) @map("category_fee") @db.Decimal(12, 2)
  advanceBookingFee Decimal  @default(0) @map("advance_booking_fee") @db.Decimal(12, 2)
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  // Relations
  order         Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  roomAndDevice roomAndDevice @relation(fields: [roomAndDeviceId], references: [id], onDelete: Restrict)

  @@map("order_items")
}

model Payment {
  id            BigInt                @id @default(autoincrement())
  orderId       BigInt                @unique @map("order_id")
  amount        Decimal               @db.Decimal(12, 2)
  method        PaymentMethod
  provider      String?               @db.VarChar(50)
  status        PaymentProviderStatus
  transactionId String?               @map("transaction_id") @db.VarChar(255)
  paidAt        DateTime?             @map("paid_at") @db.Timestamp(6)
  metadata      Json?

  // Relations
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model Notification {
  id      BigInt              @id @default(autoincrement())
  userId  BigInt              @map("user_id")
  type    String              @db.VarChar(50)
  channel NotificationChannel
  payload Json
  status  NotificationStatus
  sentAt  DateTime?           @map("sent_at") @db.Timestamp(6)

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model Session {
  id              BigInt        @id @default(autoincrement())
  orderId         BigInt        @unique @map("order_id")
  roomAndDeviceId BigInt        @map("room_and_device_id")
  startedAt       DateTime      @map("started_at") @db.Timestamp(6)
  endedAt         DateTime?     @map("ended_at") @db.Timestamp(6)
  status          SessionStatus

  // Relations
  order         Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  roomAndDevice roomAndDevice @relation(fields: [roomAndDeviceId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model AuditLog {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt?  @map("user_id")
  action    String   @db.VarChar(100)
  entity    String   @db.VarChar(100)
  entityId  BigInt?  @map("entity_id")
  meta      Json?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  // Relations
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}

model Subscription {
  id       BigInt             @id @default(autoincrement())
  ownerId  BigInt             @map("owner_id")
  plan     String             @db.VarChar(50)
  price    Decimal            @db.Decimal(12, 2)
  startsAt DateTime           @map("starts_at") @db.Timestamp(6)
  endsAt   DateTime           @map("ends_at") @db.Timestamp(6)
  status   SubscriptionStatus

  // Relations
  owner Owner @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model Admin {
  id       BigInt    @id @default(autoincrement())
  userId   BigInt    @unique @map("user_id")
  branchId BigInt    @map("branch_id")
  role     AdminRole

  // Relations
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@map("admins")
}

model Review {
  id         BigInt   @id @default(autoincrement())
  branchId   BigInt   @map("branch_id")
  customerId BigInt   @map("customer_id")
  rating     Int      @db.SmallInt
  comment    String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  // Relations
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  customer User   @relation(fields: [customerId], references: [id], onDelete: Cascade)

  // Unique constraint: one review per customer per branch
  @@unique([customerId, branchId])
  @@map("reviews")
}

model BranchHoliday {
  id          BigInt   @id @default(autoincrement())
  branchId    BigInt   @map("branch_id")
  date        DateTime @db.Date
  name        String   @db.VarChar(100) // "Hari Raya Idul Fitri", "Tahun Baru", etc
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([branchId, date])
  @@map("branch_holidays")
}

model FailedJob {
  id         BigInt    @id @default(autoincrement())
  jobType    String
  entityId   BigInt
  entityType String
  error      String    @db.Text
  stackTrace String?   @db.Text
  payload    String    @db.Text
  status     String    @default("failed") // failed, retrying, resolved
  attempts   Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  resolvedAt DateTime?

  @@index([jobType, status])
  @@index([createdAt])
}

model Announcement {
  id          BigInt               @id @default(autoincrement())
  title       String               @db.VarChar(150)
  imageFile   String?              @map("image_file") @db.Text
  description String               @db.Text
  priority    AnnouncementPriority @default(medium)
  forBranch   BigInt?              @map("for_branch")
  startDate   DateTime             @map("start_at") @db.Timestamp(6)
  endDate     DateTime             @map("end_at") @db.Timestamp(6)
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime?            @updatedAt @map("updated_at")

  branch Branch? @relation(fields: [forBranch], references: [id], onDelete: Cascade)

  @@map("announcements")
}

model BranchPaymentMethod {
  id            BigInt           @id @default(autoincrement())
  branchId      BigInt           @map("branch_id")
  method        PaymentMethod
  provider      PaymentProvider?
  isActive      Boolean          @default(true) @map("is_active")
  accountNumber String?          @map("account_number") @db.VarChar(255)
  accountName   String?          @map("account_name") @db.VarChar(255)
  qrCodeImage   String?          @map("qr_code_image") @db.Text
  instructions  String?          @db.Text
  createdAt     DateTime         @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt     DateTime?        @updatedAt @map("updated_at") @db.Timestamp(6)

  // Relations
  branch Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  orders Order[]

  @@unique([branchId, provider])
  @@index([branchId, isActive], name: "idx_branch_payment_methods_active")
  @@map("branch_payment_methods")
}
